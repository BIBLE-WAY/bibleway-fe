# ============================================
# BIBLEWAY FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control


# ============================================
# API CONFIGURATION
# ============================================

# Backend API URL (without https:// prefix)
# Production: api.bibleway.io
# Development: localhost:8000
VITE_API_URL=api.bibleway.io

# API Protocol (http or https)
# Production: https
# Development: http
VITE_API_PROTOCOL=https

# WebSocket Protocol (ws or wss)
# Production: wss
# Development: ws
VITE_WS_PROTOCOL=wss


# ============================================
# FIREBASE CONFIGURATION (Google OAuth)
# ============================================
# Project: local-22f77

VITE_FIREBASE_API_KEY=AIzaSyAy3FsmHtQ9Tg8EJs1IvIg13TQoEomw74M
VITE_FIREBASE_AUTH_DOMAIN=local-22f77.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=local-22f77
VITE_FIREBASE_STORAGE_BUCKET=local-22f77.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1031471798738
VITE_FIREBASE_APP_ID=1:1031471798738:web:c668924bd8c04737b9900b
VITE_FIREBASE_MEASUREMENT_ID=G-72XZ8NJJ37


# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment (development, staging, production)
VITE_APP_ENV=production

# Application Name
VITE_APP_NAME=BibleWay

# Application URL
VITE_APP_URL=https://bibleway.io

# Default Language
VITE_DEFAULT_LANGUAGE=en

# Enable Debug Mode (true/false)
VITE_DEBUG_MODE=false


# ============================================
# FEATURE FLAGS
# ============================================

# Enable/Disable Features
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false


# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Google Analytics (Optional)
VITE_GA_TRACKING_ID=

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=

# Sentry Environment
VITE_SENTRY_ENVIRONMENT=production


# ============================================
# DEVELOPMENT CONFIGURATION
# ============================================

# Skip SSL verification for ngrok (development only)
# Set to "true" only in development
VITE_SKIP_SSL_VERIFY=false

# Enable source maps in production (not recommended)
VITE_ENABLE_SOURCE_MAPS=false
